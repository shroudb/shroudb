#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-commit: running checks ==="

# Verify no local path patches are active
if grep -v '^#' .cargo/config.toml 2>/dev/null | grep -q '\[patch'; then
    echo "ERROR: .cargo/config.toml has active [patch] sections"
    echo "Disable patches before committing to avoid lockfile checksum mismatches"
    exit 1
fi

# fmt
echo "  fmt..."
cargo fmt --all -- --check

# clippy
echo "  clippy..."
cargo clippy --workspace --all-targets -- -D warnings

# Build the server binary (needed for integration and smoke tests)
echo "  build..."
cargo build -p shroudb

# ALL workspace tests — unit, integration, smoke
echo "  tests..."
cargo test --workspace

echo "=== pre-commit: all checks passed ==="
